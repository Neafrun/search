# ===========================================
# 사이트 잠금 (선택)
# ===========================================
# 값을 넣으면 비밀번호를 아는 사람만 사이트를 볼 수 있습니다.
# 비우면 잠금 없음 — 로컬 개발처럼 누구나 접속 가능합니다.
SITE_PASSWORD=

# 쿠키(HMAC) 서명용 비밀. 비우면 SITE_PASSWORD로 서명합니다.
# 값을 쓰지 않을 때는 이 줄을 삭제하거나 주석 처리하세요(AUTH_SECRET= 만 두면 안 됩니다).
AUTH_SECRET=

# 프로덕션에서 HTTPS 뒤에 둘 때만 1. HTTP만 쓰는 서버면 0.
# COOKIE_SECURE=

# ===========================================
# AI — Google Gemini (권장)
# ===========================================
# Google AI Studio 등에서 발급한 키를 붙여 넣습니다.
GEMINI_API_KEY=

# 모델 이름. 비우면 gemini-2.0-flash
# 예전 이름(gemini-1.5-pro 등)은 API에서 404가 나는 경우가 있습니다.
GEMINI_MODEL=

# Studio 키 대신 Cloud 등에서 받은 키만 있을 때, GEMINI_API_KEY 대신 사용 가능합니다.
GOOGLE_API_KEY=

# ===========================================
# AI — OpenAI (선택, Gemini 키가 전혀 없을 때만 대체 호출)
# ===========================================
# 보통은 비워 두면 됩니다.
OPENAI_API_KEY=

# ===========================================
# 배포(프로덕션)
# ===========================================
# 실제 도메인 (메타데이터·절대 URL용). 예: https://example.com
NEXT_PUBLIC_SITE_URL=

# 검색 색인 허용 시 1. 비우면 robots.txt에서 전체 Disallow
# NEXT_PUBLIC_ALLOW_INDEXING=

# OpenAI 폴백: Gemini 실패 시에만 사용 (선택)
# AI_ANALYSIS_FALLBACK_OPENAI=1
# OPENAI_MODEL=gpt-4o-mini

# --- 참고 ---
# 키·잠금 설정을 바꾼 뒤에는 개발 서버(npm run dev)를 다시 실행하세요.
# 429(할당량)이면 잠시 뒤 재시도하거나 AI Studio/Cloud에서 한도를 확인하세요.
